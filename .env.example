# Local paths (sensitive). Keep only paths here.
VIGILANT_INPUT_DIR="/path/to/your/input/mfs"
VIGILANT_OUTPUT_DIR="/path/to/your/output/mp4"

# Optional: Input/output directories for PDF parsing
# VIGILANT_INPUT_PDF_DIR="/path/to/pdfs"
# VIGILANT_OUTPUT_JSON_DIR="/path/to/json"

# YOLO model path (if using YOLO prefilter)
VIGILANT_YOLO_MODEL="/path/to/yolov8n.pt"

# Optional: Ollama URL (default: http://localhost:11434)
# VIGILANT_OLLAMA_URL="http://localhost:11434"

# All other settings live in config/default.yaml or config/local.yaml
